# LLM provider: "ollama" (local, free) or "openai" (paid)
LLM_PROVIDER=ollama

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# GitHub repository for DB release downloads (e.g. owner/repo)
GITHUB_REPO=YourUsername/asksql_markets

# Optional: token for private GitHub repos
GITHUB_TOKEN=

# Optional: shared secret to protect the /admin/sync endpoint
SYNC_SECRET=
